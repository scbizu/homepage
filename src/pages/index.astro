---
import FooterNote from "../components/FooterNote.astro";
import HeroSection from "../components/HeroSection.astro";
import NotebookFeed from "../components/NotebookFeed.astro";
import ProfileCard from "../components/ProfileCard.astro";
import SiteMark from "../components/SiteMark.astro";
import { homepage, type FeedEntry } from "../content/homepage";
import generatedTelegramFeed from "../content/generated/channels/telegram-feed.json";
import BaseLayout from "../layouts/BaseLayout.astro";

const generatedEntries = generatedTelegramFeed.entries as FeedEntry[];
const mergedFeed: FeedEntry[] = [...generatedEntries, ...homepage.feed];
---

<BaseLayout title={`${homepage.siteTitle} | Nace`} description={homepage.hero.subtitle}>
  <SiteMark title={homepage.siteTitle} />
  <main>
    <ProfileCard profile={homepage.profile} />
    <HeroSection hero={homepage.hero} />
    <NotebookFeed feed={mergedFeed} />
  </main>
  <FooterNote siteTitle={homepage.siteTitle} footer={homepage.footer} />
</BaseLayout>
